# PostgreSQL
POSTGRES_USER=explainer
POSTGRES_PASSWORD=explainer
POSTGRES_DB=codebase_explainer
DATABASE_URL=postgresql+asyncpg://explainer:explainer@localhost:5432/codebase_explainer

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=explainer

# OpenAI (required for Q&A and README generation)
OPENAI_API_KEY=sk-your-key-here

# Storage
REPOS_DIR=./data/repos
INDEX_DIR=./data/indexes
METADATA_DIR=./data/metadata

# Resource limits
MAX_REPO_SIZE_MB=500
MAX_FILE_COUNT=5000
MAX_FILE_SIZE_KB=512
DELETE_CLONE_AFTER_INDEX=true
RETENTION_DAYS=30

# API
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
RATE_LIMIT_PER_MINUTE=60

# Security
ALLOWED_GIT_HOSTS=github.com,www.github.com
BLOCK_PRIVATE_IPS=true
