# ─── LITE MODE (no Docker) — use: ./scripts/run-local.sh ───────────────────
LITE_MODE=true
DATABASE_URL=sqlite+aiosqlite:///./data/app.db
GRAPH_BACKEND=memory
EMBEDDING_PROVIDER=local
LLM_PROVIDER=offline

# PostgreSQL (only needed with Docker)
POSTGRES_USER=explainer
POSTGRES_PASSWORD=explainer
POSTGRES_DB=codebase_explainer

# Simplified local/demo mode
LITE_MODE=true
DATABASE_URL=sqlite+aiosqlite:///./data/app.db
GRAPH_BACKEND=memory
LLM_PROVIDER=offline

# Ollama (uncomment if installed)
# LLM_PROVIDER=ollama
# EMBEDDING_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_CHAT_MODEL=llama3.2
# Optional: if you want to wire in a live provider later
GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
INDEX_DIR=./data/indexes
METADATA_DIR=./data/metadata

# Resource limits
MAX_REPO_SIZE_MB=500
MAX_FILE_COUNT=5000
MAX_FILE_SIZE_KB=512
DELETE_CLONE_AFTER_INDEX=true
RETENTION_DAYS=30

# API
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
RATE_LIMIT_PER_MINUTE=60

# Security
ALLOWED_GIT_HOSTS=github.com,www.github.com
BLOCK_PRIVATE_IPS=true
